{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Knowledge Registry Entry",
  "type": "object",
  "required": [
    "id",
    "name",
    "status",
    "trust_level",
    "summary",
    "tags",
    "links",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "watching",
        "evaluating",
        "active",
        "paused",
        "rejected",
        "archived"
      ]
    },
    "trust_level": {
      "type": "string",
      "enum": [
        "unknown",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "summary": {
      "type": "string"
    },
    "use_cases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "url"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "install": {
      "type": "object"
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "detail_path": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    }
  },
  "additionalProperties": true
}
